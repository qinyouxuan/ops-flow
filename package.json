{
  "name": "ops-flow",
  "version": "0.1.0",
  "private": false,
  "description": "A lightweight SSH/SFTP, database and Redis operations desktop tool.",
  "author": "Ops Flow Contributors",
  "license": "AGPL-3.0-only",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis zip",
    "dist:win:zip": "npm run build && electron-builder --win zip",
    "preview": "electron-vite preview",
    "lint": "eslint ."
  },
  "build": {
    "appId": "com.opsflow.app",
    "productName": "Ops Flow",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Ops Flow"
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron-store": "^10.0.1",
    "lucide-react": "^0.468.0",
    "mysql2": "^3.11.5",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "redis": "^4.7.0",
    "ssh2": "^1.16.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^9.17.0",
    "vite": "^5.4.11"
  }
}
